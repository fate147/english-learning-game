# ===== Supabase（业务数据：用户/孩子/星星/学习记录）=====
VITE_SUPABASE_URL=https://juiyvknwmyldykzkryiv.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xswwA5L-9c-vnWtzTXCqSg_ROfNC1bE

# ===== TTS 语音（阿里云智能语音交互）=====
# 阿里云 RAM 用户 AccessKey（需授予 AliyunNLSSpeechSynthesisAccess 权限）
ALIBABA_AK=your_access_key_id
ALIBABA_SK=your_access_key_secret
# 智能语音交互控制台 → 语音合成 → 创建App 获取的 AppKey
ALIBABA_APPKEY=your_appkey
# 音色（可选，默认 aitong（爱童），儿童友好音色）
# 其他可选：luna / emily / harry / clara
ALIBABA_TTS_VOICE=aitong
# 区域（可选，默认 cn-shanghai，需与 FC 部署区域一致）
ALIBABA_REGION=cn-shanghai

# ===== 生产环境 TTS 地址（仅当使用独立 FC 时配置）=====
# 部署阿里云 FC 后，将 FC 的 HTTP 触发器地址填在这里
# VITE_VERCEL_TTS_URL=https://xxx.cn-shanghai.fc.aliyuncs.com/tts
